# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# PostgreSQL Database (deployed on 192.168.50.128)
DB_HOST=192.168.50.128
DB_PORT=5432
DB_USER=quickdesk
DB_PASSWORD=quickdesk123
DB_NAME=quickdesk_signaling

# Redis (deployed on 192.168.50.128)
REDIS_HOST=192.168.50.128
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== ICE 配置（新增） ==========
# TURN 服务器地址（多个用逗号分隔）
TURN_URLS=turn:turn.quickcoder.cc:3478

# coturn 的 use-auth-secret 共享密钥（必须和 coturn 配置中的 static-auth-secret 一致）
TURN_AUTH_SECRET=xxxxxxx

# TURN 凭据有效时间（秒），默认 86400（24小时）
TURN_CREDENTIAL_TTL=86400

# STUN 服务器（可选，Qt 端已有内置 STUN，这里可以额外添加）
STUN_URLS=stun:stun.quickcoder.cc:3478

# 管理员账号（用于管理界面登录）
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# API Key for client authentication (empty = disabled, any client can connect)
# Set this to restrict access to official clients only.
# Clients must send this key via X-API-Key header or api_key query parameter.
API_KEY=

# Allowed origins for WebClient (comma-separated, empty = disabled)
# Browsers automatically send the Origin header which cannot be spoofed by JS.
# Only pages loaded from these origins can access the signaling server.
# Example: https://web.quickdesk.cc,https://quickdesk.example.com
ALLOWED_ORIGINS=