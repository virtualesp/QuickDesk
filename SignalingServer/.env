# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# PostgreSQL Database (deployed on localhost)
DB_HOST=localhost
DB_PORT=5432
DB_USER=quickdesk
DB_PASSWORD=quickdesk123
DB_NAME=quickdesk_signaling

# Redis (deployed on localhost)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========== ICE Configuration ==========
# TURN server addresses (separated by commas)
TURN_URLS=turn:turn.quickcoder.cc:3478

# coturn shared secret (must match static-auth-secret in coturn configuration)
TURN_AUTH_SECRET=xxxxxxx

# TURN credential validity time (seconds), default 86400 (24 hours)
TURN_CREDENTIAL_TTL=86400

# STUN server
STUN_URLS=stun:stun.quickcoder.cc:3478

# Admin account (for management interface login)
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# API Key for client authentication (empty = disabled, any client can connect)
# Set this to restrict access to official clients only.
# Clients must send this key via X-API-Key header or api_key query parameter.
API_KEY=

# Allowed origins for WebClient (comma-separated, empty = disabled)
# Browsers automatically send the Origin header which cannot be spoofed by JS.
# Only pages loaded from these origins can access the signaling server.
# Example: https://web.quickdesk.cc,https://quickdesk.example.com
ALLOWED_ORIGINS=

# Aliyun SMS (optional – leave all empty to disable phone number features)
# When disabled, SMS login/register verification is not available.
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=